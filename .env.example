APP_NAME="Campaign Tracker"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=campaign_tracker
DB_USERNAME=
DB_PASSWORD=

# -------------------------------------------------------------------------
# Redis — required for queue, cache, and session in production.
# Install: sudo apt install redis-server  (Ubuntu)
#          brew install redis              (macOS)
# Use REDIS_CLIENT=predis (pure PHP, no extension) or phpredis (C extension).
# -------------------------------------------------------------------------
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# -------------------------------------------------------------------------
# Queue — set to "redis" once Redis is available. Falls back to "database".
# REDIS_QUEUE_RETRY_AFTER must stay above the longest job timeout (imports use
# $timeout = 7200s) so a long-running import is never re-dispatched while still running.
# -------------------------------------------------------------------------
QUEUE_CONNECTION=redis
REDIS_QUEUE_RETRY_AFTER=7800

# -------------------------------------------------------------------------
# Cache — set to "redis" once Redis is available. Falls back to "database".
# -------------------------------------------------------------------------
CACHE_STORE=redis

# -------------------------------------------------------------------------
# Session — set to "redis" once Redis is available. Falls back to "database".
# -------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -------------------------------------------------------------------------
# Database backups (used by the backup:database artisan command)
# Backups are stored in storage/backups and rotated after BACKUP_KEEP_DAYS.
# -------------------------------------------------------------------------
BACKUP_KEEP_DAYS=30
